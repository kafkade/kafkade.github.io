---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout title="kafkade" description="software, systems, and other things">
  <!-- Hero -->
  <section class="py-8 sm:py-12">
    <h1 class="text-[2.8rem] sm:text-[3.4rem] font-bold leading-[1.1] mb-2">
      kafkade
    </h1>
    <p class="text-[0.9rem] text-[--color-text-muted] leading-relaxed mb-6 max-w-[560px]">
      Software creator. Building tools and exploring ideas
      at the intersection of thoughtful engineering and the
      Pacific Northwest.
    </p>
    <p class="text-[0.85rem]">
      <a href="https://github.com/kafkade" class="accent">GitHub</a><span class="text-[--color-sage] mx-1">·</span>
      <a href="https://x.com/kafkade33926" class="accent">Twitter</a><span class="text-[--color-sage] mx-1">·</span>
      <a href="https://bsky.app/profile/kafkadev.bsky.social" class="accent">Bluesky</a><span class="text-[--color-sage] mx-1">·</span>
      <a href="https://patreon.com/c/kafkade" class="accent">Patreon</a><span class="text-[--color-sage] mx-1">·</span>
      <a href="https://buymeacoffee.com/kafkade" class="accent">Buy Me a Coffee</a>
    </p>
  </section>

  <hr />

  <!-- Projects -->
  <section class="py-8">
    <h2 class="text-[1.4rem] font-bold mb-6">Projects</h2>

    <div class="mb-6">
      <h3 class="text-[1rem] font-semibold mb-1">
        <a href="https://kafkade.com" class="accent">kafkade.com</a>
      </h3>
      <p class="text-[0.8rem] text-[--color-sage] mb-1">Astro · Tailwind CSS · Cloudflare Pages</p>
      <p class="text-[0.85rem] text-[--color-text-muted] leading-relaxed">
        This website — a minimal portfolio and blog deployed on Cloudflare Pages.
      </p>
    </div>

    <div class="mb-6">
      <h3 class="text-[1rem] font-semibold mb-1">
        <a href="https://github.com/kafkade" class="accent">Coming Soon</a>
      </h3>
      <p class="text-[0.8rem] text-[--color-sage] mb-1">Stay Tuned</p>
      <p class="text-[0.85rem] text-[--color-text-muted] leading-relaxed">
        More projects on the way. Follow along on GitHub.
      </p>
    </div>
  </section>

  <hr />

  <!-- Quote -->
  <section class="py-8">
    <blockquote class="border-l-[3px] border-[--color-ember] pl-5">
      <p class="text-[0.9rem] text-[--color-text-muted] italic leading-relaxed">
        "A book must be the axe for the frozen sea within us."
      </p>
      <cite class="block text-[0.8rem] text-[--color-sage] not-italic mt-2">
        — Franz Kafka
      </cite>
    </blockquote>
  </section>
</PageLayout>
