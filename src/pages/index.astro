---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout title="kafkade" description="software, systems, and other things">
  <!-- Hero -->
  <section class="py-8 sm:py-12">
    <img
      src="/avatar.png"
      alt="kafkade"
      width="120"
      height="120"
      class="rounded-full mb-5"
    />
    <h1 class="text-[2.8rem] sm:text-[3.4rem] font-bold leading-[1.1] mb-2">
      kafkade
    </h1>
    <p class="text-[0.95rem] text-[--color-text-muted] leading-relaxed mb-6 max-w-[560px]">
      Software creator. Building tools and exploring ideas
      between the terminal and the tree line.
    </p>
    <p class="text-[0.9rem]">
      <a href="https://github.com/kafkade" class="accent">GitHub</a><span class="text-[--color-sage] mx-1">·</span>
      <a href="https://x.com/kafkade33926" class="accent">Twitter</a><span class="text-[--color-sage] mx-1">·</span>
      <a href="https://bsky.app/profile/kafkadev.bsky.social" class="accent">Bluesky</a>
    </p>
  </section>

  <hr />

  <!-- Support -->
  <section class="py-8">
    <h2 class="text-[1.5rem] font-bold mb-4">Support</h2>
    <p class="text-[0.9rem] text-[--color-text-muted] leading-relaxed mb-5 max-w-[560px]">
      All my projects are free and open source. If they're useful to you,
      consider supporting their development.
    </p>
    <p class="text-[0.9rem] mb-2">
      <a href="https://github.com/sponsors/kafkade" class="accent font-medium">♥ GitHub Sponsors</a><span class="text-[--color-sage] mx-1">·</span>
      <a href="https://ko-fi.com/kafkade" class="accent font-medium">Ko-fi</a>
    </p>
    <p class="text-[0.8rem] text-[--color-sage]">
      Also on
      <a href="https://buymeacoffee.com/kafkade" class="text-[--color-sage] underline underline-offset-2">Buy Me a Coffee</a>
      and
      <a href="https://patreon.com/kafkade" class="text-[--color-sage] underline underline-offset-2">Patreon</a>
    </p>
  </section>

  <hr />

  <!-- Projects -->
  <section class="py-8">
    <h2 class="text-[1.5rem] font-bold mb-6">Projects</h2>

    <div class="mb-6">
      <h3 class="text-[1.05rem] font-semibold mb-1">
        <a href="https://kite.kafkade.com" class="accent">kite</a>
      </h3>
      <p class="text-[0.85rem] text-[--color-sage] mb-1">Rust · ratatui · tokio · Cross-platform</p>
      <p class="text-[0.9rem] text-[--color-text-muted] leading-relaxed">
        A modern TUI system resource monitor. Real-time CPU, memory, disk,
        network, and process metrics in your terminal.
        <a href="https://github.com/kafkade/kite" class="accent text-[0.85rem]">GitHub →</a>
      </p>
    </div>

    <div class="mb-6">
      <h3 class="text-[1.05rem] font-semibold mb-1">
        <a href="https://kafkade.com" class="accent">kafkade.com</a>
      </h3>
      <p class="text-[0.85rem] text-[--color-sage] mb-1">Astro · Tailwind CSS · Cloudflare Pages</p>
      <p class="text-[0.9rem] text-[--color-text-muted] leading-relaxed">
        This website — a minimal portfolio and blog deployed on Cloudflare Pages.
      </p>
    </div>
  </section>

  <hr />

  <!-- Quote -->
  <section class="py-8">
    <blockquote class="border-l-[3px] border-[--color-ember] pl-5">
      <p class="text-[0.95rem] text-[--color-text-muted] italic leading-relaxed">
        "A book must be the axe for the frozen sea within us."
      </p>
      <cite class="block text-[0.85rem] text-[--color-sage] not-italic mt-2">
        — Franz Kafka
      </cite>
    </blockquote>
  </section>
</PageLayout>
