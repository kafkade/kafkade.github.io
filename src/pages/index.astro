---
import PageLayout from '../layouts/PageLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import SocialLinks from '../components/SocialLinks.astro';
---

<PageLayout title="kafkade — Code. Craft. Cascade." description="Software creator building at the intersection of code and craft.">
  <!-- Hero -->
  <section class="pt-20 sm:pt-28 pb-16 sm:pb-20">
    <div class="flex flex-col items-center text-center">
      <!-- Logo mark -->
      <div class="mb-10 relative">
        <svg viewBox="0 0 80 60" fill="none" class="w-24 sm:w-28 opacity-90">
          <path d="M 10,52 L 40,22 L 70,52" stroke="#0A7373" stroke-width="3" fill="none" stroke-linecap="round" stroke-linejoin="round" opacity="0.2"/>
          <path d="M 16,44 L 40,16 L 64,44" stroke="#0A7373" stroke-width="3" fill="none" stroke-linecap="round" stroke-linejoin="round" opacity="0.45"/>
          <path d="M 22,36 L 40,10 L 58,36" stroke="#0A7373" stroke-width="3.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
          <circle cx="40" cy="8" r="3" fill="#EDAA25"/>
        </svg>
      </div>

      <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl font-semibold text-[--color-text-dark] [html[data-theme=light]_&]:text-[--color-text-light] mb-5 tracking-tight leading-none">
        kafkade
      </h1>

      <p class="text-base sm:text-lg text-[--color-amber] font-display font-medium tracking-wide mb-6">
        Code · Craft · Cascade
      </p>

      <p class="text-[--color-sage] max-w-md mx-auto leading-relaxed text-sm sm:text-base">
        Software creator building tools and exploring ideas
        at the intersection of thoughtful engineering and the Pacific Northwest.
      </p>

      <div class="mt-8">
        <SocialLinks />
      </div>
    </div>
  </section>

  <!-- Section divider -->
  <div class="flex items-center gap-4 my-4">
    <div class="flex-1 h-px bg-gradient-to-r from-transparent via-[--color-sage]/15 to-transparent"></div>
    <svg viewBox="0 0 20 12" fill="none" class="w-5 h-3 text-[--color-sage]/25">
      <path d="M 2,10 L 10,3 L 18,10" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
    <div class="flex-1 h-px bg-gradient-to-r from-transparent via-[--color-sage]/15 to-transparent"></div>
  </div>

  <!-- Featured Projects -->
  <section class="py-14">
    <div class="flex items-baseline justify-between mb-8">
      <h2 class="font-display text-xl sm:text-2xl font-semibold text-[--color-text-dark] [html[data-theme=light]_&]:text-[--color-text-light] tracking-tight">
        Projects
      </h2>
      <a href="/projects" class="text-xs text-[--color-sage] hover:text-[--color-teal] transition-colors font-medium uppercase tracking-wider">
        View all →
      </a>
    </div>
    <div class="grid gap-4 sm:grid-cols-2">
      <ProjectCard
        name="kafkade.com"
        description="This website — a minimal portfolio and blog built with Astro and Tailwind CSS, deployed on Cloudflare Pages."
        repo="https://github.com/kafkade/kafkade"
        url="https://kafkade.com"
        tags={['Astro', 'Tailwind CSS', 'Cloudflare']}
      />
      <ProjectCard
        name="Coming Soon"
        description="More projects on the way. Follow along on GitHub."
        repo="https://github.com/kafkade"
        tags={['Stay Tuned']}
      />
    </div>
  </section>

  <!-- Quote -->
  <section class="py-14 border-t border-[--color-sage]/10">
    <blockquote class="border-l-2 border-[--color-amber]/40 pl-6">
      <p class="italic text-[--color-sage] text-sm leading-relaxed">
        "A book must be the axe for the frozen sea within us."
      </p>
      <footer class="mt-3 text-xs text-[--color-sage]/60 not-italic font-display">
        — Franz Kafka
      </footer>
    </blockquote>
  </section>
</PageLayout>
