---
import PageLayout from '../../layouts/PageLayout.astro';
import BlogPostCard from '../../components/BlogPostCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<PageLayout title="Blog — kafkade" description="Thoughts on software, systems, and the spaces between.">
  <h1 class="text-[1.4rem] font-bold mb-2">
    Blog
  </h1>
  <p class="text-[0.85rem] text-[--color-text-muted] mb-8">
    software, systems, and other things
  </p>

  {posts.length > 0 ? (
    <div class="flex flex-col gap-4">
      {posts.map((post) => (
        <BlogPostCard
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          slug={post.id}
          tags={post.data.tags}
        />
      ))}
    </div>
  ) : (
    <p class="text-[--color-sage]/60 text-center py-16">
      No posts yet. Stay tuned.
    </p>
  )}
</PageLayout>
