---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout title="404 — kafkade" description="Page not found.">
  <section class="py-16">
    <h1 class="text-[2.5rem] font-bold mb-4">404</h1>
    <p class="text-[0.95rem] text-[--color-text-muted] mb-6">
      This page doesn't exist. Perhaps it never did.
    </p>
    <blockquote class="border-l-[3px] border-[--color-ember] pl-5 mb-8">
      <p class="text-[0.9rem] text-[--color-text-muted] italic">"Paths are made by walking."</p>
      <cite class="block text-[0.85rem] text-[--color-sage] not-italic mt-1">— Franz Kafka</cite>
    </blockquote>
    <a href="/" class="accent text-[0.9rem]">← Go home</a>
  </section>
</PageLayout>
