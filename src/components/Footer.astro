---
import SocialLinks from './SocialLinks.astro';

const currentYear = new Date().getFullYear();
---

<footer class="border-t border-[--color-sage]/15 mt-auto">
  <div class="max-w-5xl mx-auto px-6 py-10">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-6">
      <!-- Brand -->
      <div class="flex flex-col items-center sm:items-start gap-2">
        <span class="font-display text-sm font-bold text-[--color-sage]/60">kafkade</span>
        <p class="text-xs text-[--color-sage]/40">
          Code. Craft. Cascade.
        </p>
      </div>

      <!-- Social -->
      <SocialLinks />

      <!-- Copyright -->
      <p class="text-xs text-[--color-sage]/40">
        &copy; {currentYear} kafkade
      </p>
    </div>
  </div>
</footer>
