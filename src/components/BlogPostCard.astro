---
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  slug: string;
  tags?: string[];
}

const { title, description, pubDate, slug, tags = [] } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<a href={`/blog/${slug}`} class="group block no-underline">
  <article class="rounded-lg border border-[--color-sage]/15 bg-[--color-surface-dark] [html[data-theme=light]_&]:bg-white p-6 transition-all hover:border-[--color-teal]/40 hover:shadow-lg hover:shadow-[--color-teal]/5">
    <div class="flex items-center gap-3 mb-3">
      <time datetime={pubDate.toISOString()} class="text-xs text-[--color-sage]/80">
        {formattedDate}
      </time>
      {tags.length > 0 && (
        <div class="flex gap-1.5">
          {tags.slice(0, 2).map((tag) => (
            <span class="text-xs px-2 py-0.5 rounded-full bg-[--color-teal]/10 text-[--color-teal]">
              {tag}
            </span>
          ))}
        </div>
      )}
    </div>
    <h3 class="font-display text-lg font-bold text-[--color-text-dark] [html[data-theme=light]_&]:text-[--color-text-light] group-hover:text-[--color-teal] transition-colors mb-2">
      {title}
    </h3>
    <p class="text-sm text-[--color-sage] leading-relaxed">
      {description}
    </p>
  </article>
</a>
