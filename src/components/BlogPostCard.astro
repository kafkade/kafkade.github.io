---
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  slug: string;
  tags?: string[];
}

const { title, description, pubDate, slug, tags = [] } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<a href={`/blog/${slug}`} class="block no-invert mb-6">
  <article>
    <h3 class="text-[1rem] font-semibold mb-1">
      <span class="accent underline decoration-2 underline-offset-[3px] decoration-[--color-ember]">{title}</span>
    </h3>
    <p class="text-[0.8rem] text-[--color-sage] mb-1">
      <time datetime={pubDate.toISOString()}>{formattedDate}</time>
      {tags.length > 0 && ` · ${tags.join(' · ')}`}
    </p>
    <p class="text-[0.85rem] text-[--color-text-muted] leading-relaxed">
      {description}
    </p>
  </article>
</a>
