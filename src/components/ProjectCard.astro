---
interface Props {
  name: string;
  description: string;
  url?: string;
  repo?: string;
  tags?: string[];
}

const { name, description, url, repo, tags = [] } = Astro.props;
---

<div class="group relative rounded-xl border border-[--color-sage]/10 bg-[--color-surface-dark]/50 [html[data-theme=light]_&]:bg-white/80 p-6 transition-all duration-300 hover:border-[--color-teal]/30 hover:bg-[--color-surface-dark] [html[data-theme=light]_&]:hover:bg-white hover:shadow-xl hover:shadow-[--color-teal]/5 hover:-translate-y-0.5">
  <div class="flex items-start justify-between mb-3">
    <h3 class="font-display text-base font-semibold text-[--color-text-dark] [html[data-theme=light]_&]:text-[--color-text-light] group-hover:text-[--color-teal] transition-colors tracking-tight">
      {name}
    </h3>
    <div class="flex items-center gap-2 shrink-0 ml-4">
      {repo && (
        <a
          href={repo}
          target="_blank"
          rel="noopener noreferrer"
          class="text-[--color-sage]/70 hover:text-[--color-teal] transition-colors"
          aria-label={`${name} on GitHub`}
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
          </svg>
        </a>
      )}
      {url && (
        <a
          href={url}
          target="_blank"
          rel="noopener noreferrer"
          class="text-[--color-sage]/70 hover:text-[--color-teal] transition-colors"
          aria-label={`Visit ${name}`}
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
          </svg>
        </a>
      )}
    </div>
  </div>

  <p class="text-sm text-[--color-sage] mb-4 leading-relaxed">
    {description}
  </p>

  {tags.length > 0 && (
    <div class="flex flex-wrap gap-2">
      {tags.map((tag) => (
        <span class="text-xs px-2 py-0.5 rounded-full bg-[--color-teal]/10 text-[--color-teal]">
          {tag}
        </span>
      ))}
    </div>
  )}
</div>
