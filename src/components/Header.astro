---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/projects', label: 'Projects' },
  { href: '/blog', label: 'Blog' },
  { href: '/about', label: 'About' },
];

const currentPath = Astro.url.pathname;
---

<header class="w-full border-b border-[--color-border] mb-12">
  <div class="max-w-[720px] mx-auto px-6 py-6">
    <div class="flex items-center justify-between flex-wrap gap-4">
      <a href="/" class="no-invert font-bold text-base hover:text-[--color-ember] transition-colors">
        kafkade
      </a>
      <nav class="flex items-center gap-6">
        {navLinks.map(({ href, label }) => (
          <a
            href={href}
            class:list={[
              'text-[0.85rem] no-underline transition-colors',
              currentPath === href || (href !== '/' && currentPath.startsWith(href))
                ? 'text-[--color-text] font-medium underline decoration-2 underline-offset-[3px]'
                : 'text-[--color-text-muted] hover:text-[--color-text]',
            ]}
          >
            {label}
          </a>
        ))}
      </nav>
    </div>
  </div>
</header>
