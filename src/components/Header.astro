---
import ThemeToggle from './ThemeToggle.astro';

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/projects', label: 'Projects' },
  { href: '/blog', label: 'Blog' },
  { href: '/about', label: 'About' },
];

const currentPath = Astro.url.pathname;
---

<header class="w-full border-b border-[--color-sage]/15">
  <nav class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="group flex items-center gap-2 no-underline logo-link">
      <svg viewBox="0 0 32 32" fill="none" class="w-8 h-8 shrink-0" aria-hidden="true">
        <path d="M 6,26 L 16,6 L 26,26" stroke="#0A7373" stroke-width="3" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M 12,16 L 16,26 L 20,16" stroke="#0A7373" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round" opacity="0.3"/>
        <circle cx="16" cy="5" r="2" fill="#EDAA25"/>
      </svg>
      <span class="font-display text-lg font-bold text-[--color-text-dark] [html[data-theme=light]_&]:text-[--color-text-light] group-hover:text-[--color-teal] transition-colors">
        kafkade
      </span>
    </a>

    <!-- Navigation -->
    <div class="flex items-center gap-6">
      <ul class="hidden sm:flex items-center gap-6 list-none m-0 p-0">
        {navLinks.map(({ href, label }) => (
          <li>
            <a
              href={href}
              class:list={[
                'text-sm transition-colors no-underline',
                currentPath === href || (href !== '/' && currentPath.startsWith(href))
                  ? 'text-[--color-teal] font-medium'
                  : 'text-[--color-sage] hover:text-[--color-teal-light]',
              ]}
            >
              {label}
            </a>
          </li>
        ))}
      </ul>
      <ThemeToggle />

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="sm:hidden text-[--color-sage] hover:text-[--color-teal] transition-colors"
        aria-label="Toggle menu"
      >
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile navigation -->
  <div id="mobile-menu" class="hidden sm:hidden border-t border-[--color-sage]/15">
    <ul class="flex flex-col px-6 py-4 gap-3 list-none m-0 p-0">
      {navLinks.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={[
              'text-sm block py-1 no-underline',
              currentPath === href || (href !== '/' && currentPath.startsWith(href))
                ? 'text-[--color-teal] font-medium'
                : 'text-[--color-sage] hover:text-[--color-teal-light]',
            ]}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
