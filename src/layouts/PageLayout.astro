---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  wide?: boolean;
}

const { title, description, ogImage, wide = false } = Astro.props;
---

<BaseLayout title={title} description={description} ogImage={ogImage}>
  <Header />
  <main class:list={['flex-1 mx-auto w-full px-6 py-12', wide ? 'max-w-5xl' : 'max-w-2xl']}>
    <slot />
  </main>
  <Footer />
</BaseLayout>
