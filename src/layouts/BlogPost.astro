---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  tags?: string[];
}

const { title, description, pubDate, updatedDate, tags = [] } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const formattedUpdate = updatedDate?.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={`${title} — kafkade`} description={description}>
  <Header />
  <main class="flex-1 max-w-[720px] mx-auto w-full px-6">
    <article class="py-8">
      <header class="mb-8">
        <h1 class="text-[1.7rem] sm:text-[2.1rem] font-bold leading-tight mb-3">
          {title}
        </h1>
        <div class="text-[0.85rem] text-[--color-sage]">
          <time datetime={pubDate.toISOString()}>{formattedDate}</time>
          {updatedDate && (
            <span> · Updated {formattedUpdate}</span>
          )}
        </div>
        {tags.length > 0 && (
          <div class="mt-2 text-[0.85rem] text-[--color-sage]">
            {tags.join(' · ')}
          </div>
        )}
      </header>

      <div class="prose">
        <slot />
      </div>
    </article>
  </main>
  <Footer />
</BaseLayout>

<style>
  .prose {
    line-height: 1.75;
    color: var(--color-text-muted);
    font-size: 0.95rem;
  }

  .prose :global(h2) {
    font-size: 1.3rem;
    font-weight: 700;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    color: var(--color-text);
  }

  .prose :global(h3) {
    font-size: 1.1rem;
    font-weight: 700;
    margin-top: 2rem;
    margin-bottom: 0.5rem;
    color: var(--color-text);
  }

  .prose :global(p) {
    margin-bottom: 1.25rem;
  }

  .prose :global(ul), .prose :global(ol) {
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
    list-style-type: square;
  }

  .prose :global(li) {
    margin-bottom: 0.4rem;
  }

  .prose :global(blockquote) {
    border-left: 3px solid var(--color-ember);
    padding-left: 1.25rem;
    margin: 1.5rem 0;
    font-style: italic;
  }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2rem 0;
  }

  .prose :global(strong) {
    color: var(--color-text);
    font-weight: 600;
  }
</style>
