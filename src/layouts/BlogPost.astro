---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  tags?: string[];
}

const { title, description, pubDate, updatedDate, tags = [] } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const formattedUpdate = updatedDate?.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={`${title} — kafkade`} description={description}>
  <Header />
  <main class="flex-1 mx-auto w-full max-w-2xl px-6 py-12">
    <article>
      <header class="mb-10">
        <h1 class="font-display text-3xl sm:text-4xl font-semibold text-[--color-text-dark] [html[data-theme=light]_&]:text-[--color-text-light] mb-4 tracking-tight leading-tight">
          {title}
        </h1>
        <div class="flex items-center gap-4 text-sm text-[--color-sage]">
          <time datetime={pubDate.toISOString()}>{formattedDate}</time>
          {updatedDate && (
            <span>· Updated {formattedUpdate}</span>
          )}
        </div>
        {tags.length > 0 && (
          <div class="flex flex-wrap gap-2 mt-4">
            {tags.map((tag) => (
              <span class="text-xs px-2.5 py-1 rounded-full bg-[--color-teal]/10 text-[--color-teal]">
                {tag}
              </span>
            ))}
          </div>
        )}
      </header>

      <div class="prose">
        <slot />
      </div>
    </article>
  </main>
  <Footer />
</BaseLayout>

<style>
  .prose {
    font-family: var(--font-body);
    line-height: 1.8;
    color: var(--color-text-dark);
  }

  :global(html[data-theme="light"]) .prose {
    color: var(--color-text-light);
  }

  .prose :global(h2) {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 700;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    color: var(--color-text-dark);
  }

  :global(html[data-theme="light"]) .prose :global(h2) {
    color: var(--color-text-light);
  }

  .prose :global(h3) {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .prose :global(p) {
    margin-bottom: 1.25rem;
  }

  .prose :global(ul), .prose :global(ol) {
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
  }

  .prose :global(li) {
    margin-bottom: 0.5rem;
  }

  .prose :global(blockquote) {
    border-left: 3px solid var(--color-teal);
    padding-left: 1rem;
    margin: 1.5rem 0;
    font-style: italic;
    color: var(--color-sage);
  }

  .prose :global(img) {
    border-radius: 0.5rem;
    margin: 1.5rem 0;
  }

  .prose :global(a) {
    color: var(--color-teal);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .prose :global(a:hover) {
    color: var(--color-teal-light);
  }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid color-mix(in srgb, var(--color-sage) 25%, transparent);
    margin: 2rem 0;
  }
</style>
