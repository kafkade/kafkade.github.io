---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'Software creator. Code. Craft. Cascade.',
  ogImage = '/og-default.png',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const environment: string = __ENVIRONMENT__;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />
    <meta property="og:site_name" content="kafkade" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />

    <!-- Favicon -->
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <!-- RSS -->
    <link rel="alternate" type="application/rss+xml" title="kafkade" href="/rss.xml" />

    <!-- Sitemap -->
    <link rel="sitemap" href="/sitemap-index.xml" />

    {/* Baked-in environment tag so devtools can identify production vs preview deploys.
        Renders as <!-- Environment: production --> or <!-- Environment: beta --> etc.
        Uses set:html because Astro does not interpolate expressions inside HTML comments. */}
    <Fragment set:html={`<!-- Environment: ${environment} -->`} />

    <!-- Theme initialization — restore preference before first paint to prevent FOUC -->
    <script is:inline>
      (function () {
        var saved = localStorage.getItem('theme');
        var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        var theme = saved || (prefersDark ? 'dark' : 'light');
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>
  </head>
  <body class="min-h-screen flex flex-col antialiased">
    <slot />
  </body>
</html>
